<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ARTICLE_HEADLINE}}",
  "description": "{{ARTICLE_DESCRIPTION}}",
  "image": "{{SITE_URL}}/{{ARTICLE_IMAGE_PATH}}",
  "datePublished": "{{ISO_8601_PUBLISHED}}",
  "dateModified": "{{ISO_8601_MODIFIED}}",
  "author": {
    "@type": "Person",
    "name": "{{AUTHOR_NAME}}",
    "url": "{{AUTHOR_URL}}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ORG_NAME}}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{SITE_URL}}/{{LOGO_PATH}}"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ABSOLUTE_PAGE_URL}}"
  }
}
</script>
<!--
Place inside <head> on each content/article page. Dates must be real ISO 8601
(e.g. 2026-06-26T09:00:00Z). Author/publisher must be truthful. For non-article pages,
use the appropriate type (BlogPosting, FAQPage, HowTo) only if that content genuinely exists
on the page. Remove this comment in the final output.
-->
